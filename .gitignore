# Ignore target directory
target/

# Allow Maven wrapper jar
!.mvn/wrapper/maven-wrapper.jar

# Exclude target directories under src/main and src/test
!**/src/main/**/target/
!**/src/test/**/target/

### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### IntelliJ IDEA ###
.idea
*.iws
*.iml
*.ipr

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# Ignore build directories except under src/main and src/test
build/
!**/src/main/**/build/
!**/src/test/**/build/

### VS Code ###
.vscode/
    